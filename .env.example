# Local secrets / environment overrides (git-ignored). Copy to ".env":
#     Windows:  copy .env.example .env
#     mac/Linux: cp .env.example .env
#
# NOTE: FCC downloads need NO API token — the pipeline uses the same public
# endpoint the broadbandmap.fcc.gov "Download" buttons call. This file is only
# needed if you switch source.backend to "redshift".

# Redshift (copy connection details from DBeaver → your connection → Edit):
# REDSHIFT_HOST=your-cluster.xxxxx.us-east-1.redshift.amazonaws.com
# REDSHIFT_DB=your_database
# REDSHIFT_USER=your_username
# REDSHIFT_PASSWORD=your_password
#
# Then set source.backend: redshift in config/pipeline.yaml (or use --backend redshift).
# Use DBeaver to browse tables and paste the real schema into source.redshift.coverage_query.
# Set analysis.vintages to match your warehouse as_of_date format (often YYYY-MM-DD).
