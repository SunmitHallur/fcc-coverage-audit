# FCC Broadband Data Collection API credentials.
#
# Each user supplies THEIR OWN token (tokens are tied to an individual FCC
# account and can be revoked). Do NOT commit real values.
#
# Setup:
#   1. Copy this file to ".env"  (it is git-ignored, so it stays local)
#          Windows:  copy .env.example .env
#          mac/Linux: cp .env.example .env
#   2. Create a free account at https://broadbandmap.fcc.gov
#   3. Sign in -> click your username (top-right) -> "Manage API Access" -> Generate
#   4. Paste your email + token below.

FCC_API_USERNAME=you@example.com
FCC_API_TOKEN=your-44-character-token-here

# Redshift (only if you switch source.backend to "redshift"):
# REDSHIFT_HOST=
# REDSHIFT_DB=
# REDSHIFT_USER=
# REDSHIFT_PASSWORD=
